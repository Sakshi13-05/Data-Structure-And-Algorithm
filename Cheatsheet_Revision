//--1--
public class MasterTest {
    static int score = 100;     // Static Variable
    int energy = 50;           // Instance Variable

    public static void main(String[] args) {
        MasterTest player = new MasterTest();

        int score = 20;        // Local Variable 1
        int energy = 10;       // Local Variable 2

        player.play(30);

        System.out.println("A: " + score);
        System.out.println("B: " + player.score);
        System.out.println("C: " + energy);
        System.out.println("D: " + player.energy);

        MasterTest player2 = new MasterTest();
        System.out.println("E: " + player2.score);
    }

    public void play(int energy) {
        // 'energy' parameter is 30
        this.energy = energy + 5;
        score = score + 10;
    }
}

//--2--
public class Interview {
    static int globalCount = 0; // The Billboard
    int data = 10;              // The Private Locker

    public static void main(String[] args) {
        Interview p1 = new Interview();
        Interview p2 = new Interview();

        int globalCount = 50;   // The Scrap Paper (Local in main)
        int data = 5;           // Another Scrap Paper (Local in main)

        // The Big Move
        p1.update(p2, 100);

        System.out.println("Q1: " + globalCount);
        System.out.println("Q2: " + p1.globalCount);
        System.out.println("Q3: " + p1.data);
        System.out.println("Q4: " + p2.data);
    }

    public void update(Interview otherObj, int data) {
        // 'data' here is 100 (The Parameter)

        this.data = data + 20;
        otherObj.data = 500;

        globalCount = globalCount + 1;
    }
}
